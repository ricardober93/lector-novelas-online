generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  READER
  CREATOR
  ADMIN
}

enum ContentType {
  MANGA
  COMIC
  MANHUA
  VISUAL_NOVEL
  OTHER
}

enum SeriesStatus {
  DRAFT
  ACTIVE
  COMPLETED
  SUSPENDED
}

enum ChapterStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  role          Role      @default(READER)
  showAdult     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  series        Series[]
  readingHistory ReadingHistory[]
  moderations   Moderation[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Series {
  id            String    @id @default(cuid())
  creatorId     String
  title         String
  description   String?
  type          ContentType
  isAdult       Boolean   @default(false)
  status        SeriesStatus @default(DRAFT)
  coverImage    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creator       User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  volumes       Volume[]
  moderations   Moderation[]

  @@index([creatorId])
  @@map("series")
}

model Volume {
  id            String    @id @default(cuid())
  seriesId      String
  number        Int
  title         String?
  createdAt     DateTime  @default(now())

  series        Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  chapters      Chapter[]

  @@unique([seriesId, number])
  @@index([seriesId])
  @@map("volumes")
}

model Chapter {
  id            String    @id @default(cuid())
  volumeId      String
  number        Int
  title         String?
  pageCount     Int       @default(0)
  status        ChapterStatus @default(PENDING)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  volume        Volume    @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  pages         Page[]
  readingHistory ReadingHistory[]
  moderations   Moderation[]

  @@unique([volumeId, number])
  @@index([volumeId])
  @@index([status])
  @@map("chapters")
}

model Page {
  id            String    @id @default(cuid())
  chapterId     String
  number        Int
  imageUrl      String
  width         Int?
  height        Int?

  chapter       Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, number])
  @@index([chapterId])
  @@map("pages")
}

model ReadingHistory {
  id            String    @id @default(cuid())
  userId        String
  chapterId     String
  lastPage      Int       @default(1)
  progress      Float     @default(0)
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter       Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
  @@map("reading_history")
}

model Moderation {
  id            String    @id @default(cuid())
  seriesId      String?
  chapterId     String?
  status        ModerationStatus @default(PENDING)
  reviewerId    String?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?

  reviewer      User?     @relation(fields: [reviewerId], references: [id])
  series        Series?   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  chapter       Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([reviewerId])
  @@index([seriesId])
  @@index([chapterId])
  @@map("moderations")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
